    "backup.error.operationInProgress" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Another data operation is already in progress. Please wait and try again." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "另一項資料操作正在進行，請稍候再試。" } }
