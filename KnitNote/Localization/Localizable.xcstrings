    "backup.error.exportFailed" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "KnitNote couldn't create a backup. Please try again." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法建立 KnitNote 備份，請再試一次。" } }
      }
    },
    "backup.error.invalid" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This backup is damaged or incomplete and can't be restored." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此備份已損毀或不完整，無法還原。" } }
