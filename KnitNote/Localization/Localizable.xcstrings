    "backup.error.storageOrAccess" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "KnitNote couldn't access the backup, or there isn't enough storage space." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "KnitNote 無法存取備份，或裝置儲存空間不足。" } }
